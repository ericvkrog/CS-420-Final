{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "ChromaCode",
  "scopeName": "source.chroma",
  "patterns": [
    { "include": "#comment" },
    { "include": "#blue-line" },
    { "include": "#green-line" },
    { "include": "#yellow-line" },
    { "include": "#purple-line" },
    { "include": "#red-line" }
  ],
  "repository": {
    "comment": {
      "match": "//.*$",
      "name": "comment.line.double-slash.chroma"
    },
    "blue-line": {
      "match": "(?i)^(\\s*)(BLUE)\\b(.*)$",
      "captures": {
        "2": { "name": "keyword.chroma.blue" },
        "3": { "name": "meta.chroma.blue.content" }
      }
    },
    "green-line": {
      "match": "(?i)^(\\s*)(GREEN)\\b(.*)$",
      "captures": {
        "2": { "name": "keyword.chroma.green" },
        "3": { "name": "meta.chroma.green.content" }
      }
    },
    "yellow-line": {
      "match": "(?i)^(\\s*)(YELLOW)\\b(.*)$",
      "captures": {
        "2": { "name": "keyword.chroma.yellow" },
        "3": { "name": "meta.chroma.yellow.content" }
      }
    },
    "purple-line": {
      "match": "(?i)^(\\s*)(PURPLE)\\b(.*)$",
      "captures": {
        "2": { "name": "keyword.chroma.purple" },
        "3": { "name": "meta.chroma.purple.content" }
      }
    },
    "red-line": {
      "match": "(?i)^(\\s*)(RED)\\b(.*)$",
      "captures": {
        "2": { "name": "keyword.chroma.red" },
        "3": { "name": "meta.chroma.red.content" }
      }
    }
  }
}
